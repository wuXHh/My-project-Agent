APP_ENV=dev
APP_NAME=multiagent-content-factory

# DB
# - MVP 默认用 SQLite（无需额外服务）
# - 未来部署可切到 Postgres（并启用 pgvector）
DATABASE_URL=sqlite+pysqlite:///./data/app.db

# Object storage (MVP: 本地目录)
OBJECT_STORAGE_MODE=local
LOCAL_STORAGE_DIR=./data/storage

# Auth (MVP 简化)
JWT_SECRET=change-me
JWT_ISSUER=multiagent-content-factory
JWT_AUDIENCE=web
JWT_EXPIRES_MINUTES=4320

# Celery (可选：异步执行)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_ALWAYS_EAGER=1

# Embeddings (MVP: sentence-transformers)
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ModelRouter (MVP: stub)
LLM_PROVIDER=stub

